# Redis Cluster Configuration
# Generated by Ansible

# Basic settings
bind 127.0.0.1
port 6379
protected-mode no
tcp-backlog 511

# Logging
dir /var/log/redis
loglevel notice
logfile /var/log/redis/redis-server.log

# Databases
dbnum 16

# Replication
# slaveof <masterip> <masterport>

# Persistence
appendonly yes
appendfilename "appendonly.aof"
appendfsync everysec

# RDB Persistence
save "900 1"
save "300 10"
save "60 10000"

# Memory management
maxmemory 256mb
maxmemory-policy allkeys-lru

# Cluster
# cluster-enabled yes
# cluster-config-file nodes-6379.conf

# Security
# Password configured in deployment

# Renames
rename-command CONFIG ""][0-9A-Fa-f]{32}"
rename-command DEBUG ""][0-9A-Fa-f]{32}"
rename-command FLUSHALL ""][0-9A-Fa-f]{32}"
