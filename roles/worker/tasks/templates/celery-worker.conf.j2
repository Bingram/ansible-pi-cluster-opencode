# Celery Worker Configuration
# Generated by Ansible

broker_url = 'redis://:{{ redis_password | default('cluster_queue') }}@{{ controller_ip | default('rk01.local') }}:{{ redis_port | default(6379) }}/0'
result_backend = 'redis://:{{ redis_password | default('cluster_queue') }}@{{ controller_ip | default('rk01.local') }}:{{ redis_port | default(6379) }}/1'

worker_concurrency = {{ celery_worker_concurrency | default(4) }}
worker_prefetch_multiplier = {{ celery_worker_prefetch_multiplier | default(1) }}

worker_loglevel = 'INFO'
worker_send_task_events = True
worker_prefetch_retry_interval = 1

result_expires = 21600  # 6 hours
task_serializer = 'json'
accept_content = ['json']

# Task routing
task_acks_late = True
task_reject_on_worker_lost = True
task_default_queue = 'default'

# Rate limiting
task_annotations = {
    'tasks.default': {
        'rate_limit': '1000/h',
    },
}

# Auto discover celery tasks
discover_celery_app_autodiscovery = True
