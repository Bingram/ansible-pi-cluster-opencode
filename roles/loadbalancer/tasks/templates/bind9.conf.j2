# Generated by Ansible - Do not edit manually
# Load Balancer BIND9 Configuration

options {
    // Run as a service
    pid-file "/var/run/named/named.pid";
    
    // Listen on all interfaces
    listen-on port 53 { any; };
    listen-on-v6 port 53 { any; };
    
    // Disable recursion for security
    recursion no;
    
    // Allow queries from local network
    allow-query { localhost; };
    allow-query-cache { localhost; };
    
    // Disable transfers
    allow-transfer { none; };
    
    // Disable DNSSEC validation by default
    dnssec-validation no;
    
    // Logging
    logging {
        channel default_debug {
            file "files/named" debug;
        };
        category queries {
            default_debug;
        };
    };
    
    // Secured zone transfers
    secured-transfer-in yes;
    secured-transfer-out yes;
    
    // No queries allowed to master servers
    allow-query-master no;
    
    // No recursive queries for master servers
    allow-recursion-to master no;
    
    // Include zone files
    include "/var/lib/bind/*.zone";
    
    // Include local configuration
    include "/etc/bind/*.conf";
};

// Zone configuration
zone "cluster.local" IN {
    type master;
    file "/var/lib/bind/cluster.local.zone";
};
