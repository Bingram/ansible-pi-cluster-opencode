# Prometheus configuration
# ===========================

# Global settings
global {
  scrape_interval        "15s"
  evaluation_interval    "15s"
  external_labels       {
    monitor              "ansible-pi-cluster"
  }
}

# Alertmanager configuration
alerting {
  alertmanagers {
    static_configs {
      targets [
          # Add alertmanager target here if configured
      ]
    }
  }
}

# Rule files
rule_files:
  # - "first_rules.yml"
  # - "second_rules.yml"

# Scrape configurations
scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Node Exporter from all nodes
  - job_name: 'node_exporter'
    static_configs:
      - targets:
          - {{ controller_ip | default('192.168.1.10') }}:9100
          - {{ storage_controller_ip | default('192.168.1.20') }}:9100
          - 192.168.1.30:9100
          - 192.168.1.31:9100
          - 192.168.1.32:9100

  # Blackbox Exporter for DNS monitoring
  - job_name: 'blackbox'
    metrics_path: /probe
    params:
      module:
        - http_Head
    static_configs:
      - targets:
          - {{ loadbalancer_ip | default('192.168.1.5') }}:53